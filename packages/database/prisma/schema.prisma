generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT") // Optional: direct connection for migrations (bypasses PgBouncer)
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  venues        Venue[]
  events        Event[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Venue {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  adminPin            String?
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  tokenExpiresAt      DateTime?
  backgroundImage     String?
  active              Boolean      @default(true)
  userId              String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs               QueuedSong[]
  topTracks           VenueTrack[]

  @@index([userId])
}

model QueuedSong {
  id         String   @id @default(cuid())
  venueId    String
  spotifyUri String
  spotifyId  String
  title      String
  artist     String
  albumArt   String?
  votes      Int       @default(1)
  played     Boolean   @default(false)
  playedAt   DateTime?
  createdAt  DateTime  @default(now())
  venue      Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  votes_rel  Vote[]

  @@index([venueId, played])
  @@index([venueId, played, votes])
  @@index([spotifyId])
}

model Vote {
  id        String     @id @default(cuid())
  songId    String
  sessionId String
  createdAt DateTime   @default(now())
  song      QueuedSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, sessionId])
  @@index([songId])
  @@index([createdAt])
}

model VenueTrack {
  id            String   @id @default(cuid())
  venueId       String
  spotifyId     String
  spotifyUri    String
  title         String
  artist        String
  albumArt      String?
  totalRequests Int      @default(1)
  lastRequested DateTime @default(now())
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, spotifyId])
  @@index([venueId, totalRequests])
}

model Event {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique
  accessCode          String      @unique
  adminPin            String?
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  tokenExpiresAt      DateTime?
  startsAt            DateTime
  endsAt              DateTime
  active              Boolean     @default(true)
  maxSongsPerUser     Int         @default(3)
  allowExplicit       Boolean     @default(true)
  ownerId             String
  createdAt           DateTime    @default(now())
  owner               User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  songs               EventSong[]

  @@index([ownerId])
  @@index([accessCode])
}

model EventSong {
  id         String      @id @default(cuid())
  eventId    String
  addedBy    String?
  spotifyUri String
  spotifyId  String
  title      String
  artist     String
  albumArt   String?
  votes      Int         @default(1)
  played     Boolean     @default(false)
  playedAt   DateTime?
  createdAt  DateTime    @default(now())
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes_rel  EventVote[]

  @@index([eventId, played])
  @@index([spotifyId])
  @@index([eventId, played, votes])
}

model EventVote {
  id        String    @id @default(cuid())
  songId    String
  sessionId String
  createdAt DateTime  @default(now())
  song      EventSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, sessionId])
  @@index([songId])
  @@index([createdAt])
}
